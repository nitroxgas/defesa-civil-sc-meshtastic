# Copie este bloco para o seu /config/apps/apps.yaml do AppDaemon
# e ajuste os placeholders conforme sua instalação.

defesa_civil_sc_alertas:
  module: defesa_civil_sc_alertas
  class: DefesaCivilSCAlertas

  # Entidade notify criada pela integração Meshtastic no Home Assistant.
  # Exemplo comum: notify.mesh_channel_alertas_sc
  notify_entity: notify.mesh_channel_<NOME_DO_CANAL>

  # Node ID numérico do gateway Meshtastic usado para filtrar mensagens diretas.
  # Substitua por seu ID real. Não publique o ID real se considerar sensível.
  gateway_node_id: 0000000000

  # Intervalo fixo de polling em minutos. Se 0 ou omitido, usa 1/4 do período
  # informado pelo feed (ex: hourly -> 15 min, daily -> 360 min).
  interval_minutes: 0

  # true: envia o alerta mais recente armazenado ao iniciar, para teste.
  # false: operação normal, lendo o feed e enviando apenas novos alertas.
  test_mode: false

  # Palavra-gatilho (contida na mensagem) para resposta de alertas via DM.
  # Padrão: ALERTAS
  trigger_word: ALERTAS

  # Máximo de alertas retornados na resposta via DM.
  # Padrão: valor de MAX_ALERTS_REPLY (normalmente 2 ou 3).
  # max_alerts_reply: 3

  # Máximo de alertas armazenados no histórico local.
  # Padrão: valor de MAX_HISTORY (normalmente 10).
  # max_history: 10

  # Filtro regional: envia apenas alertas que mencionem as regiões configuradas.
  # Se disabled (padrão), todos os alertas são enviados.
  # region_filter:
  #   enabled: true
  #   mode: both          # mesorregiao | municipio | both
  #   mesorregioes:
  #     - Grande Florianópolis
  #     - Vale do Itajaí
  #   municipios:
  #     - Florianópolis
  #     - Blumenau
